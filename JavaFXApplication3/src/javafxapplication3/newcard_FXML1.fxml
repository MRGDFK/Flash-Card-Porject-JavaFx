<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxapplication3.Newcard_FXML1Controller">
   <children>
      <Label fx:id="scenepane" layoutX="22.0" layoutY="14.0" prefHeight="40.0" prefWidth="750.0" text="Enter the Questions and Answer" textFill="WHITE" />
      <Label layoutX="22.0" layoutY="54.0" prefHeight="28.0" prefWidth="750.0" text="Question:" textFill="WHITE" />
      <Label layoutX="22.0" layoutY="265.0" prefHeight="28.0" prefWidth="765.0" text="Answer:" textFill="WHITE" />
      <TextField fx:id="txtfldque" layoutX="14.0" layoutY="93.0" onAction="#txtfldclickquestion" prefHeight="159.0" prefWidth="765.0" />
      <TextField fx:id="txtfldans" layoutX="15.0" layoutY="293.0" onAction="#txtfldclickanswer" prefHeight="159.0" prefWidth="765.0" />
      <Button fx:id="btnnext" layoutX="683.0" layoutY="463.0" mnemonicParsing="false" onAction="#clicknext" prefHeight="10.0" prefWidth="89.0" text="NEXT" />
      <Button fx:id="btnexit" layoutX="728.0" layoutY="19.0" mnemonicParsing="false" onAction="#exitclick" text="Exit" />
      <Button fx:id="btnsave" layoutX="14.0" layoutY="463.0" mnemonicParsing="false" onAction="#clicksave" prefHeight="31.0" prefWidth="61.0" text="Save" />
   </children>
</AnchorPane>
